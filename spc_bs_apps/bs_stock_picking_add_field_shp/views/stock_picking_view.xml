<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_picking_form_inherit_tracking" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.tracking</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="bs_effective_date_change.view_stock_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_of_transfer']" position="after">
                <field name="tracking_number" />
                <field name="tracking_number_returns" />
            </xpath>
        </field>
    </record>
</odoo>