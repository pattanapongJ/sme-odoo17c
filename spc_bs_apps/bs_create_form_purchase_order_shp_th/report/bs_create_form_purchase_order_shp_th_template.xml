<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- custom report template -->
    <template id="request_layout">
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <!-- Multicompany -->
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>

        <!-- header -->
        <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
             <div class="row pt-2 pb-1" style="font-family: 'Kanit-Light';">
                <t t-call="bs_create_form_purchase_order_shp_th.report_compay_info"/>
                <div class="col-3 text-end pd-3">
                    <span style="font-size: 25px" >ใบสั่งซื้อสินค้า</span>
                    <br/>
                    <span style="font-size: 25px" >Purchase Order</span>
                    <br/>
                    <div t-if="report_type == 'pdf'" class="text-muted text-right col" style="font-size:12.5px">
                        <li class="list-inline-item">
                            <div class="row">
                                <span>หน้าที่</span>
                                <span class="page" />/
                                <span class="topage" />
                            </div>
                        </li>
                    </div>
                </div>
            </div>
            <t t-call="bs_create_form_purchase_order_shp_th.report_partner_info"/>
        </div>

        <!-- content  or article-->
        <div t-attf-class="article o_report_layout_standard o_company_#{company.id}_layout"
            t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
            t-att-data-oe-lang="o and o.env.context.get('lang')">
             <!-- Added fix for uneven table header when there are more than 2 pages. -->
             <div style="margin-top: -12px"></div>
            <t t-raw="0" />
        </div>

        <!-- footer -->
         <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout">
            <t t-call="bs_create_form_purchase_order_shp_th.report_footer" />
        </div>
    </template>
</odoo>