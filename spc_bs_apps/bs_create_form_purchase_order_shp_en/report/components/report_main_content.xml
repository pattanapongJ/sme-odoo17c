<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_main_content">
        <div class="row pt-3 pb-5" style="font-family: 'Kanit-Light'; font-size: 13.64px;">
            <div class="col-12 p-0 m-0 pt-2">
                <table class="table table-borderless">
                    <thead style="background-color: #d9d9d9">
                        <tr>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle; width: 46px;">
                                <p class="p-0 m-0">No.</p>
                            </th>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 96px;">
                                <p class="p-0 m-0">Part Code</p>
                            </th>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 106px;">
                                <p class="p-0 m-0">Details</p>
                            </th>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 46px;">
                                <p class="p-0 m-0">Quantity</p>
                            </th>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle; width: 66px;">
                                <p class="p-0 m-0">UoM</p>
                            </th>
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 76px;">
                                <p class="p-0 m-0">Price/UoM</p>
                            </th>
                            <!-- <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 45px;">
                                <p class="p-0 m-0">Discount</p>
                            </th> -->
                            <th class="text-center" scope="col" style="display: table-cell;
                                            text-align: center;
                                            vertical-align: middle;  width: 96px;">
                                <p class="p-0 m-0">
                                    <span>Amount</span>(<span t-field="o.currency_id.name"/>)
                                </p>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="line_number" t-value="0" />
                        <t t-foreach="o.order_line" t-as="line">
                            <t t-if="line.display_type">
                                <tr>
                                    <td colspan="7" class="text-left">
                                        <t t-if="line.display_type == 'line_note'">
                                            <span class="font-italic" t-field="line.name"/>
                                        </t>
                                        <t t-if="line.display_type == 'line_section'">
                                            <span class="font-weight-bold" t-field="line.name"/>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="not line.display_type">
                                <tr>
                                    <td scope="row" class="text-center">
                                        <t t-set="line_number" t-value="line_number + 1"/>
                                        <span t-esc="line_number" />
                                    </td>
                                    <td class="text-left">
                                        <span t-field="line.product_id.default_code"/>
                                    </td>
                                    <td class="text-left">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.product_qty" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.product_uom"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.gross_unit_price" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <!-- <td class="text-right">
                                        <span t-field="line.multi_disc_amount" t-options='{"widget": "float", "precision": 2}'/>
                                    </td> -->
                                    <td class="text-right">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </template>
</odoo>
