<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_partner_info">
        <div class="row border-top border-dark border-bottom border-dark pt-2 pb-2"
            style="font-family: 'Kanit-Light'; font-size: 13.64px">
            <div class="col-6 p-1">
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Customer Code: </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.del_partner.ref">
                                <span t-esc="o.del_partner.ref" />
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.del_partner.ref">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Customer Name: </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.del_partner.firstname">
                                <span t-field="o.del_partner.firstname" />
                                <span t-field="o.del_partner.lastname" />
                            </t>
                            <t t-elif="o.del_partner.name_company">
                                <span t-field="o.del_partner.name_company" />
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Tax ID: </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.del_partner.vat">
                                <span t-esc="o.del_partner.vat" />
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.del_partner.vat">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Address: </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <t t-if="o.del_partner.street">
                            <span t-field="o.del_partner.street" />
                        </t>
                        <t t-if="o.del_partner.street2">
                            <span t-field="o.del_partner.street2" />
                        </t>
                        <t t-if="o.del_partner.city">
                            <span t-esc="o.del_partner.city" />
                        </t>
                        <br />
                        <t t-if="o.del_partner.state_id">
                            <span t-esc="o.del_partner.state_id.name" />
                        </t>
                        <t t-if="o.del_partner.zip">
                            <span t-esc="o.del_partner.zip" />
                        </t>
                        <t t-if="o.del_partner.country_id">
                            <span t-field="o.del_partner.country_id.name" />
                        </t>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Order Reference: </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.sale_order">
                                <span t-field="o.sale_order.name" />
                            </t>
                            <t t-if="not o.sale_order.name">
                                -
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Tracking Number: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <span>
                            <t t-if="'tracking_number' in o._fields and o.tracking_number">
                                <span t-esc="o.tracking_number" />
                            </t>
                            <t t-else="">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 mb-0 p-0 text-left ">
                        <span style="font-weight: bold;">Tracking Number Returns: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <span>
                            <t t-if="'tracking_number_returns' in o._fields and o.tracking_number_returns">
                                <span t-esc="o.tracking_number_returns" />
                            </t>
                            <t t-else="">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-6 p-1" style="background-color: #d0d0d0;">
                <div class="row">
                    <div class="col-5 p-0 mb-0 text-left">
                        <span style="font-weight: bold;">RMA NO: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <span t-field="o.name" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 p-0 mb-0  text-left">
                        <span style="font-weight: bold;">RMA Dates: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <span t-field="o.date"
                            t-options='{"widget": "date", "format": "dd/MM/yyyy"}' />
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 p-0 mb-0  text-left">
                        <span style="font-weight: bold;">Shipping reference: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <t t-if="o.delivery_order">
                            <span t-field="o.delivery_order" />
                        </t>
                        <t t-if="not o.delivery_order">
                            <span> - </span>
                        </t>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 p-0 mb-0  text-left">
                        <span style="font-weight: bold;">Responsible: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <t t-if="o.create_uid.name">
                            <span t-field="o.create_uid.name" />
                        </t>
                        <t t-if="not o.create_uid.name">
                            <span> - </span>
                        </t>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 p-0 mb-0  text-left">
                        <span style="font-weight: bold;">Return Address : </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <t t-if="o.del_partner.street">
                            <span t-field="o.del_partner.street" />
                        </t>
                        <t t-if="o.del_partner.street2">
                            <span t-field="o.del_partner.street2" />
                        </t>
                        <t t-if="o.del_partner.city">
                            <span t-esc="o.del_partner.city" />
                        </t>
                        <br />
                        <t t-if="o.del_partner.state_id">
                            <span t-esc="o.del_partner.state_id.name" />
                        </t>
                        <t t-if="o.del_partner.zip">
                            <span t-esc="o.del_partner.zip" />
                        </t>
                        <t t-if="o.del_partner.country_id">
                            <span t-field="o.del_partner.country_id.name" />
                        </t>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5 p-0 mb-0  text-left">
                        <span style="font-weight: bold;">Subject: </span>
                    </div>
                    <div class="col-7 p-0 mb-0 text-left">
                        <t t-if="o.subject">
                            <span t-field="o.subject" />
                        </t>
                        <t t-if="not o.subject">
                            <span> - </span>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
