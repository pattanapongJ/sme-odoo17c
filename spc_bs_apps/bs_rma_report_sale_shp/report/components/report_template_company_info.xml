<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_compay_info">
        <div class="col-2 p-0 m-0"
            style="
                            display: -webkit-box; 
                            -webkit-box-pack: center;  
                            -webkit-box-orient: vertical;
                            display: flex;
                            justify-content: center;
                            flex-direction: column;">
            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                style="max-width: 90%;" alt="Logo" />
        </div>
        <div class="col-6 text-start">
            <div class="row pb-2" style="margin-bottom: -6px; font-size: 20px;">
                <span t-field="o.company_id.name" />
                <t t-if="o.company_id.branch">
                    <span>(</span>
                    <span t-field="o.company_id.branch" />
                    <span>)</span>
                </t>
            </div>
            <div class="row">
                <span style="font-size: 12.5px" t-field="o.company_id.street" />
                <span style="font-size: 12.5px" t-field="o.company_id.street2" />
                <span style="font-size: 12.5px" t-field="o.company_id.city" />
                <br/>
                <span style="font-size: 12.5px" t-field="o.company_id.state_id" />
                <span style="font-size: 12.5px" t-field="o.company_id.zip" />
                <span style="font-size: 12.5px" t-field="o.company_id.country_id" />
            </div>
            <div class="row" style="font-size: 12.5px">
                <span>Tel : </span>
                <span>
                    <t t-if="o.company_id.phone">
                        <span t-esc="o.company_id.phone" />
                    </t>
                </span>
                <span class="pr-1">
                    <t t-if="not o.company_id.phone">
                        <span> - </span>
                    </t>
                </span>
            </div>
            <div class="row" style="font-size: 12.5px">
                <span>Website : </span>
                <span class="pr-1">
                    <t t-if="o.company_id.website">
                        <span t-esc="o.company_id.website" />
                    </t>
                </span>
                <span>
                    <t t-if="not o.company_id.website">
                        <span> - </span>
                    </t>
                </span>
                <span>/ E-mail : </span>
                <span>
                    <t t-if="o.company_id.email">
                        <span t-esc="o.company_id.email" />
                    </t>
                </span>
                <span>
                    <t t-if="not o.company_id.email">
                        <span> - </span>
                    </t>
                </span>
            </div>
            <div class="row" style="font-size: 12.5px">
                <span>Tax ID: </span>
                <span>
                    <t t-if="o.company_id.vat">
                        <span t-esc="o.company_id.vat" />
                    </t>
                </span>
                <span>
                    <t t-if="not o.company_id.vat">
                        <span> - </span>
                    </t>
                </span>
            </div>
        </div>
    </template>
</odoo>